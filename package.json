{
  "name": "boxed-products",
  "version": "1.0.0",
  "description": "Boxed Sneakers - Premium sneakers e-commerce platform with Firebase authentication",
  "main": "index.html",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:auth": "jest --testPathPattern=auth",
    "test:product": "jest --testPathPattern=product",
    "test:ui": "jest --testPathPattern=ui",
    "build": "mkdir -p dist && cp -r *.html pages assets src data dist/ 2>/dev/null || xcopy /E /I /Y *.html pages assets src data dist\"",
    "build:clean": "rm -rf dist || rmdir /S /Q dist"
  },
  "keywords": [
    "e-commerce",
    "sneakers",
    "firebase",
    "authentication"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.60.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ]
  }
}
